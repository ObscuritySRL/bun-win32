  "peerDependencies": {
    "typescript": "^5"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/ObscuritySRL/bun-win32#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/ObscuritySRL/bun-win32.git",
    "directory": "packages/uia"
  },
  "type": "module",
  "version": "1.0.0",
  "main": "./index.ts",
  "keywords": [
    "accessibility",
    "automation",
    "bun",
    "desktop",
    "e2e",
    "ffi",
    "playwright",
    "testing",
    "typescript",
    "uiautomation",
    "win32",
    "windows"
  ],
  "files": [
    "AI.md",
    "README.md",
    "automation.ts",
    "cache.ts",
    "com.ts",
